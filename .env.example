# Zoho Mail SMTP — used by /api/contact to email form submissions to the team
# and send the visitor an auto-reply. Copy this file to .env.local and fill in.
# Generate SMTP_PASS as an app-specific password:
#   Zoho Mail -> Settings -> Security -> App Passwords (SMTP/IMAP access enabled).
SMTP_HOST=smtp.zoho.com        # EU: smtp.zoho.eu | India: smtp.zoho.in | AU: smtp.zoho.com.au
SMTP_PORT=465                  # 465 = SSL, 587 = STARTTLS
SMTP_USER=info@codinc.co       # full Zoho mailbox address (also the From address)
SMTP_PASS=                     # put the real value in .env.local, NOT here
CONTACT_TO=info@codinc.co      # where contact submissions are delivered
